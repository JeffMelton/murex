FROM opensuse/tumbleweed:latest

ARG GO_VERSION=1.24.2

# Base tooling + test deps
RUN zypper -n ref \
 && zypper -n install -y \
      ca-certificates curl git make gcc gcc-c++ procps \
      aspell aspell-en tmux \
 && zypper -n clean

# Install Go (match go.mod)
RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz \
    | tar -C /usr/local -xz

ENV PATH=/usr/local/go/bin:/go/bin:$PATH \
    GOPATH=/go \
    EXT_LDFLAGS=" " \
    OS_FLAVOR="opensuse-tumbleweed-homepath" \
    OUT_DIR="/results" \
    TMUX_TMPDIR="/tmp" \
    HOME="/home/user@example.com" \
    USER="user@example.com" \
    LOGNAME="user@example.com"

# Prepare home path as a symlink to a UUID-like directory
ARG HOME_UUID_PATH=/home/00000000-0000-0000-0000-000000000000
RUN mkdir -p "$HOME_UUID_PATH" \
 && ln -s "$HOME_UUID_PATH" "/home/user@example.com"

WORKDIR /src

# Always copy local tree; optionally replace with a clone (see REPO_MODE)
COPY . /src

ARG REPO_MODE=local            # local|clone
ARG REPO_URL=https://github.com/lmorg/murex.git
ARG REPO_REF=develop
ENV REPO_REF=${REPO_REF}
RUN if [ "$REPO_MODE" = "clone" ]; then \
      rm -rf /src && git clone --depth 1 --branch "$REPO_REF" "$REPO_URL" /src; \
    fi

RUN go version && git --version && aspell --version && tmux -V

VOLUME ["/results"]

RUN cat > /usr/local/bin/run-tests <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
export PATH=/usr/local/go/bin:/go/bin:$PATH
OS="$OS_FLAVOR"
# Prefer git branch, fallback to REPO_REF (build arg)
BRANCH="$(git -C /src rev-parse --abbrev-ref HEAD 2>/dev/null || echo "${REPO_REF}")"
OUTDIR="${OUT_DIR:-/results}"
mkdir -p "$OUTDIR"
BRANCH_SAN="$(echo "$BRANCH" | tr '/' '_' )"
LOGFILE="$OUTDIR/test-${OS}-${BRANCH_SAN}.log"
echo "HOME is: $HOME" | tee "$LOGFILE"
echo "Running tests on $OS, branch $BRANCH..." | tee -a "$LOGFILE"
(make -C /src clean || true) >>"$LOGFILE" 2>&1
mkdir -p /run/tmux || true
chmod 1777 /run/tmux || true
make -C /src test 2>&1 | tee -a "$LOGFILE"
EOF
RUN chmod +x /usr/local/bin/run-tests

CMD ["/usr/local/bin/run-tests"]
